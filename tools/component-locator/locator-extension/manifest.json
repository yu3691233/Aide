{
  "manifest_version": 3,
  "name": "AideLink 组件定位器",
  "version": "2.1.0",
  "description": "Ctrl+Click 定位网页组件，匹配项目代码，生成 AI 修改指令",
  "permissions": ["activeTab", "storage", "sidePanel", "clipboardWrite"],
  "host_permissions": ["<all_urls>", "http://localhost:5000/*"],
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["content.js"],
    "css": ["content.css"],
    "run_at": "document_idle"
  }],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "AideLink 组件定位器",
    "default_icon": "icon.png"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "icons": {
    "48": "icon.png",
    "128": "icon.png"
  }
}
