# AideLink 环境变量配置
# 复制此文件为 .env 并填入实际值

# MiniMax API Key（必填）
MINIMAX_API_KEY=

# MiniMax API 地址（可选，默认值见代码）
# MINIMAX_URL=https://api.minimax.chat/v1/chat/completions

# ── 以下为可选配置，默认值见代码 ──

# .env 文件路径（可选，默认 ../.env）
# AIDELINK_ENV_PATH=

# Flask 服务端口（可选，默认 5000）
# AIDELINK_FLASK_SERVICE_PORT=5000

# FRP 服务器地址（可选，留空不启用 FRP）
# AIDELINK_FRPS_HOST=
